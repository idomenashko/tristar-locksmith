# No environment variables required for basic site

# Lead form email delivery (required for contact form)
RESEND_API_KEY=re_...
# Comma-separated — all addresses receive the same lead email
LEAD_TO_EMAIL=tristarlocksmith@gmail.com,office@mr-keyslocksmith.com
# Leave LEAD_FROM_EMAIL empty to use Resend sandbox (onboarding@resend.dev)
# Set to "Tristar Locksmith <noreply@tristarlocksmith.com>" once domain is verified
LEAD_FROM_EMAIL=Tristar Locksmith Leads <leads@tristarlocksmith.com>

# Google Analytics 4 — from analytics.google.com (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity — from clarity.microsoft.com (10-char project ID)
NEXT_PUBLIC_CLARITY_PROJECT_ID=xxxxxxxxxx

# Google Search Console — HTML tag verification content value only
GOOGLE_SITE_VERIFICATION=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
