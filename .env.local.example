# Sanity CMS credentials — copy to .env.local and fill in values
# Get project ID from: https://sanity.io/manage
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-04-16

# Write token — create at https://sanity.io/manage → API → Tokens → Add API token (Editor role)
# Only needed for seeding data (scripts/seed-sanity.ts) — never commit this file
SANITY_API_WRITE_TOKEN=
